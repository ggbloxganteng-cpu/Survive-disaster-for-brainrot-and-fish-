-- // FIND GAME OBJECTS SMART
-- =====================================================

local function FindObjectsByKeywords(keywords, excludeKeywords)
    local results = {}
    excludeKeywords = excludeKeywords or {}

    for _, obj in pairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        local matched = false
        local excluded = false

        for _, kw in pairs(keywords) do
            if name:find(kw:lower()) then
                matched = true
                break
            end
        end

        for _, ekw in pairs(excludeKeywords) do
            if name:find(ekw:lower()) then
                excluded = true
                break
            end
        end

        if matched and not excluded then
            table.insert(results, obj)
        end
    end

    return results
end

local function FindNearestFrom(objects)
    if not HumanoidRootPart or not HumanoidRootPart.Parent then return nil, math.huge end
    local nearest, minDist = nil, math.huge
    for _, obj in pairs(objects) do
        if obj and obj.Parent then
            local pos = GetPartPosition(obj)
            if pos then
                local d = (pos - HumanoidRootPart.Position).Magnitude
                if d < minDist then
                    minDist = d
                    nearest = obj
                end
            end
        end
    end
    return nearest, minDist
end

