-- =====================================================
-- // UTILITY FUNCTIONS
-- =====================================================

local function FireAllRemotes(keyword, ...)
    local args = {...}
    for name, remote in pairs(Remotes) do
        if name:find(keyword:lower()) then
            pcall(function()
                if remote:IsA("RemoteEvent") then
                    remote:FireServer(unpack(args))
                elseif remote:IsA("RemoteFunction") then
                    remote:InvokeServer(unpack(args))
                end
            end)
        end
    end
end

local function TweenTo(pos, speed)
    if not HumanoidRootPart or not HumanoidRootPart.Parent then return false end
    speed = speed or 0.2
    local dist = (HumanoidRootPart.Position - pos).Magnitude
    local time = math.clamp(dist / 200, 0.05, speed)
    local tween = TweenService:Create(
        HumanoidRootPart,
        TweenInfo.new(time, Enum.EasingStyle.Linear),
        {CFrame = CFrame.new(pos)}
    )
    tween:Play()
    tween.Completed:Wait()
    return true
end

local function InstantTP(pos)
    if HumanoidRootPart and HumanoidRootPart.Parent then
        HumanoidRootPart.CFrame = CFrame.new(pos)
    end
end

local function TouchPart(part)
    if not part or not part.Parent then return end
    pcall(function()
        firetouchinterest(HumanoidRootPart, part, 0)
        task.wait()
        firetouchinterest(HumanoidRootPart, part, 1)
    end)
end

local function ClickDetectorClick(obj)
    pcall(function()
        local cd = obj:FindFirstChildWhichIsA("ClickDetector", true)
        if cd then
            fireclickdetector(cd)
        end
    end)
end

local function GetPartPosition(obj)
    if obj:IsA("BasePart") then
        return obj.Position
    elseif obj:IsA("Model") then
        if obj.PrimaryPart then return obj.PrimaryPart.Position end
        local p = obj:FindFirstChildWhichIsA("BasePart", true)
        if p then return p.Position end
    end
    return nil
end

local function InteractWithObject(obj)
    if not obj or not obj.Parent then return end
    -- Touch all parts
    pcall(function()
        if obj:IsA("BasePart") then
            TouchPart(obj)
        end
        for _, part in pairs(obj:GetDescendants()) do
            if part:IsA("BasePart") then
                TouchPart(part)
            end
        end
    end)
    -- Click detector
    ClickDetectorClick(obj)
    -- Proximity prompt
    pcall(function()
        for _, pp in pairs(obj:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then
                fireproximityprompt(pp)
            end
        end
        if obj:IsA("BasePart") or obj:IsA("Model") then
            local pp = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
            if pp then
                fireproximityprompt(pp)
            end
        end
    end)
end

